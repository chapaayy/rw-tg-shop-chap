# ======================================================================
# Пример файла окружения
# Скопируйте в .env и заполните своими значениями
# cp .env.example .env
# nano .env 
# ======================================================================

# ----------------------------------------------------------------------
# 1. Бот и интерфейс
# ----------------------------------------------------------------------
BOT_TOKEN=your_bot_token_here
ADMIN_IDS=comma_separated_admin_ids

# ----------------------------------------------------------------------
MY_DEVICES_SECTION_ENABLED=False
TRIAL_HWID_DEVICE_LIMIT=2
PAID_HWID_DEVICE_LIMIT=8

# ----------------------------------------------------------------------
DISABLE_WELCOME_MESSAGE=True
START_COMMAND_DESCRIPTION=
DEFAULT_LANGUAGE=ru
TELEGRAM_PROXY_URL=

# ----------------------------------------------------------------------
# 2. Внешние ссылки
# ----------------------------------------------------------------------
SUPPORT_LINK=https://t.me/your_support_link
SERVER_STATUS_URL=https://status.yourdomain.tld/status/your_service
TERMS_OF_SERVICE_URL=https://example.com/tos
SUBSCRIPTION_MINI_APP_URL=

# ----------------------------------------------------------------------
# 3. Обязательная подписка на канал
# ----------------------------------------------------------------------
REQUIRED_CHANNEL_SUBSCRIBE_TO_USE=False
REQUIRED_CHANNEL_ID=
REQUIRED_CHANNEL_LINK=https://t.me/your_channel

# ----------------------------------------------------------------------
# 4. Webhook и web-сервер
# ----------------------------------------------------------------------
WEBHOOK_BASE_URL=https://webhooks.yourdomain.tld
TELEGRAM_WEBHOOK_PATH=/webhook/telegram
TELEGRAM_WEBHOOK_SECRET=

# ----------------------------------------------------------------------
WEB_SERVER_HOST=0.0.0.0
WEB_SERVER_PORT=8080

# ----------------------------------------------------------------------
# 5. PostgreSQL
# ----------------------------------------------------------------------
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=rw-tg-shop-chap-db
POSTGRES_PORT=5432
POSTGRES_DB=postgres

# ----------------------------------------------------------------------
# 6. Интеграция с панелью
# ----------------------------------------------------------------------
PANEL_API_URL=http://your_panel_api_url/api
PANEL_API_KEY=your_panel_api_key
PANEL_WEBHOOK_SECRET=

# ----------------------------------------------------------------------
# 6.1 Redis (FSM, cache, антиспам, lock-и)
# ----------------------------------------------------------------------
REDIS_ENABLED=False
REDIS_URL=
REDIS_HOST=rw-tg-shop-chap-redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_KEY_PREFIX=rw_tg_shop_chap
REDIS_CONNECT_TIMEOUT_SECONDS=2
REDIS_SOCKET_TIMEOUT_SECONDS=2
REDIS_FSM_STATE_TTL_SECONDS=86400
REDIS_FSM_DATA_TTL_SECONDS=86400
REDIS_PAYMENT_LOCK_TTL_SECONDS=15
REDIS_PROMO_LOCK_TTL_SECONDS=15
REDIS_PANEL_EVENT_DEDUP_TTL_SECONDS=300
REDIS_CACHE_PANEL_USER_TTL_SECONDS=15
REDIS_CACHE_PANEL_STATS_TTL_SECONDS=30

# ----------------------------------------------------------------------
# 7. Платежные методы (вкл/выкл и порядок)
# ----------------------------------------------------------------------
STARS_ENABLED=True
STARS_PROVIDER_TOKEN=
PLATEGA_ENABLED=False
CRYPTOPAY_ENABLED=False
# ----------------------------------------------------------------------
YOOKASSA_ENABLED=False
FREEKASSA_ENABLED=False
SEVERPAY_ENABLED=False
PAYMENT_METHODS_ORDER=stars,platega,cryptopay,severpay,yookassa,freekassa

# ----------------------------------------------------------------------
# 9. Nalog.ru
# ----------------------------------------------------------------------
NALOGO_INN=your_inn
NALOGO_PASSWORD=your_nalogo_password
NALOGO_RECEIPT_NAME_SUBSCRIPTION=subscription {months} months
NALOGO_RECEIPT_NAME_TRAFFIC=traffic package {gb} GB

# ----------------------------------------------------------------------
# 8. YooKassa
# ----------------------------------------------------------------------
YOOKASSA_SHOP_ID=your_shop_id
YOOKASSA_SECRET_KEY=your_secret_key
YOOKASSA_RETURN_URL=https://t.me/your_bot
YOOKASSA_DEFAULT_RECEIPT_EMAIL=your_email@example.com
YOOKASSA_VAT_CODE=1
YOOKASSA_TAX_SYSTEM_CODE=
YOOKASSA_AUTOPAYMENTS_ENABLED=False
YOOKASSA_AUTOPAYMENTS_REQUIRE_CARD_BINDING=True

# ----------------------------------------------------------------------
# 10. FreeKassa
# ----------------------------------------------------------------------
FREEKASSA_MERCHANT_ID=your_shop_id
FREEKASSA_API_KEY=your_api_key
FREEKASSA_SECOND_SECRET=your_second_secret
FREEKASSA_PAYMENT_IP=
FREEKASSA_PAYMENT_METHOD_ID=44

# ----------------------------------------------------------------------
# 11. CryptoPay
# ----------------------------------------------------------------------
CRYPTOPAY_TOKEN=
CRYPTOPAY_NETWORK=mainnet
CRYPTOPAY_CURRENCY_TYPE=fiat
CRYPTOPAY_ASSET=RUB

# ----------------------------------------------------------------------
# 12. Platega
# ----------------------------------------------------------------------
PLATEGA_BASE_URL=https://app.platega.io
PLATEGA_MERCHANT_ID=
PLATEGA_SECRET=
PLATEGA_PAYMENT_METHOD=2
PLATEGA_RETURN_URL=
PLATEGA_FAILED_URL=

# ----------------------------------------------------------------------
# 13. SeverPay
# ----------------------------------------------------------------------
SEVERPAY_BASE_URL=https://severpay.io/api/merchant
SEVERPAY_MID=
SEVERPAY_TOKEN=
SEVERPAY_RETURN_URL=
SEVERPAY_LIFETIME_MINUTES=

# ----------------------------------------------------------------------
# 14. Тарифы подписки
# ----------------------------------------------------------------------
1_MONTH_ENABLED=True
RUB_PRICE_1_MONTH=130
STARS_PRICE_1_MONTH=0

3_MONTHS_ENABLED=True
RUB_PRICE_3_MONTHS=390
STARS_PRICE_3_MONTHS=0

6_MONTHS_ENABLED=True
RUB_PRICE_6_MONTHS=780
STARS_PRICE_6_MONTHS=0

12_MONTHS_ENABLED=True
RUB_PRICE_12_MONTHS=1560
STARS_PRICE_12_MONTHS=0

# ----------------------------------------------------------------------
# 15. Пакеты трафика
# ----------------------------------------------------------------------
TRAFFIC_PACKAGES=10:199,50:799
STARS_TRAFFIC_PACKAGES=10:2500

# ----------------------------------------------------------------------
# 16. Уведомления о подписке
# ----------------------------------------------------------------------
SUBSCRIPTION_NOTIFICATIONS_ENABLED=True
SUBSCRIPTION_NOTIFY_ON_EXPIRE=True
SUBSCRIPTION_NOTIFY_AFTER_EXPIRE=True
SUBSCRIPTION_NOTIFY_DAYS_BEFORE=3

# ----------------------------------------------------------------------
# 17. Партнерская система
# ----------------------------------------------------------------------
PARTNER_PROGRAM_ENABLED=True
REFERRAL_WITHDRAWALS_ENABLED=True
REFERRAL_WITHDRAWAL_MIN_AMOUNT_RUB=0
REFERRAL_WITHDRAWAL_HOLD_DAYS=14
REFERRAL_WITHDRAWAL_REQUESTS_CHAT_ID=
REFERRAL_WITHDRAWAL_REQUESTS_THREAD_ID=

# ----------------------------------------------------------------------
# 18. Лимиты пользователей и squads
# ----------------------------------------------------------------------
USER_TRAFFIC_LIMIT_GB=0
USER_TRAFFIC_STRATEGY=NO_RESET
USER_SQUAD_UUIDS=uuid1,uuid2,uuid3
USER_EXTERNAL_SQUAD_UUID=

# ----------------------------------------------------------------------
# 19. Триал
# ----------------------------------------------------------------------
TRIAL_ENABLED=True
TRIAL_DURATION_DAYS=5
TRIAL_TRAFFIC_LIMIT_GB=0
TRIAL_TRAFFIC_STRATEGY=NO_RESET

# ----------------------------------------------------------------------
# 20. Обработка ссылок
# ----------------------------------------------------------------------
CRYPT4_ENABLED=False
CRYPT4_REDIRECT_URL=

# ----------------------------------------------------------------------
# 21. Логи
# ----------------------------------------------------------------------
LOGS_PAGE_SIZE=10
LOG_LEVEL=INFO
LOG_STORE_MESSAGE_CONTENT=False
LOG_STORE_RAW_UPDATES=False
LOG_EXPORT_INCLUDE_SENSITIVE=False
LOG_ADMIN_HIDE=False
LOG_DEFAULT_CHAT_ID=-1001234567890
LOG_DEFAULT_THREAD_ID=

LOG_NEW_USERS_CHAT_ID=
LOG_NEW_USERS_THREAD_ID=

LOG_PAYMENTS_CHAT_ID=
LOG_PAYMENTS_THREAD_ID=

LOG_PROMO_ACTIVATIONS_CHAT_ID=
LOG_PROMO_ACTIVATIONS_THREAD_ID=

LOG_TRIAL_ACTIVATIONS_CHAT_ID=
LOG_TRIAL_ACTIVATIONS_THREAD_ID=

LOG_SUSPICIOUS_ACTIVITY_CHAT_ID=
LOG_SUSPICIOUS_ACTIVITY_THREAD_ID=
LOG_NEW_USERS=True
LOG_PAYMENTS=True
LOG_PROMO_ACTIVATIONS=True
LOG_TRIAL_ACTIVATIONS=True
LOG_SUSPICIOUS_ACTIVITY=True

# ----------------------------------------------------------------------
# 22. Прочее
# ----------------------------------------------------------------------
DISCOUNT_PROMO_PAYMENT_TIMEOUT_MINUTES=10
INLINE_PARTNER_THUMBNAIL_URL=https://cdn-icons-png.flaticon.com/512/1077/1077114.png
INLINE_USER_STATS_THUMBNAIL_URL=https://cdn-icons-png.flaticon.com/512/681/681494.png
INLINE_FINANCIAL_STATS_THUMBNAIL_URL=https://cdn-icons-png.flaticon.com/512/2769/2769339.png
INLINE_SYSTEM_STATS_THUMBNAIL_URL=https://cdn-icons-png.flaticon.com/512/2920/2920277.png

